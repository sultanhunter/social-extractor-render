# Required shared auth token (must match Vercel)
SOCIAL_EXTRACTOR_API_TOKEN=

# Decodo proxy
DECODO_PROXY_HOST=isp.decodo.com
DECODO_PROXY_PORT=
DECODO_PROXY_USERNAME=
DECODO_PROXY_PASSWORD=
DECODO_PROXY_USE_SESSION=true

# Optional direct proxy URL instead of host/port/user/pass
# DECODO_PROXY_URL=http://user:pass@host:port

# Optional Instagram session cookie fallback
INSTAGRAM_SESSIONID=

# Optional: full cookies.txt content (used when instagram_cookies.txt file is unavailable)
INSTAGRAM_COOKIES_CONTENT=

# Optional binary path overrides
YT_DLP_PATH=yt-dlp
GALLERY_DL_PATH=gallery-dl

# Optional transcript extraction (Gemini)
GOOGLE_GEMINI_API_KEY=
GEMINI_TRANSCRIBE_MODEL=gemini-3.1-flash-lite-preview

# Optional Cloudflare R2 (video archival)
# If configured, downloaded videos are uploaded to R2 and a permanent URL is returned.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=
